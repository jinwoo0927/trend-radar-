# 유튜브 공식 Data API v3 키 (https://console.cloud.google.com 에서 발급)
# 설정하면 유튜브 인기 급상승 영상 실데이터가 수집됩니다.
YOUTUBE_API_KEY=

# 수집 대상 국가 코드 (기본 KR)
YOUTUBE_REGION=KR

# 자동 수집 간격(분, 기본 60)
COLLECT_INTERVAL_MIN=60

# 서버 포트 (기본 3600)
PORT=3600

# 데모(샘플) 데이터 생성 — 기본 비활성. 1/true 로 켜면 틱톡/인스타/스레드에
# 파이프라인 시연용 가짜 데이터가 생성됩니다(각 카드에 "데모" 배지 표시).
# 기본값(비활성)에서는 100% 실데이터만 수집됩니다.
DEMO_DATA=

# ─────────────────────────────────────────────────────────────
# AI 기능 (해부·아이디어·콘텐츠 스튜디오) — 아래 중 하나만 설정하면 활성화됩니다.
# 비용 0으로 쓰려면 무료 제공자(Gemini 또는 Groq)를 사용하세요.
# 프로바이더 자동 감지 순서: gemini → openai → anthropic (AI_PROVIDER로 강제 지정 가능)

# (무료·추천) Google Gemini — 카드 불필요. https://aistudio.google.com/apikey 에서 발급
GEMINI_API_KEY=

# (무료) Groq / OpenRouter / 로컬 Ollama 등 OpenAI 호환 API
#   Groq: https://console.groq.com/keys (무료), OPENAI_BASE_URL 비워두면 Groq 기본
#   Ollama(로컬·완전무료): OPENAI_BASE_URL=http://localhost:11434/v1, OPENAI_API_KEY=ollama, AI_MODEL=llama3.1
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

# (유료·최고품질) Anthropic Claude. https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=

# 프로바이더/모델 강제 지정 (선택). AI_PROVIDER=gemini|openai|anthropic
AI_PROVIDER=
AI_MODEL=

# ─────────────────────────────────────────────────────────────
# 유튜브 대본(자막) 수집 — yt-dlp 사용, API 키 불필요·무료.
# 설치: pip install yt-dlp  (서버 환경에 python 필요)
# 기본 실행 커맨드는 "python -m yt_dlp". 다르면 아래로 지정.
YTDLP_CMD=

# ─────────────────────────────────────────────────────────────
# 데이터 영속화 (배포용) — 설정하면 파일 대신 Supabase Postgres 에 저장합니다.
# 로컬 개발 시에는 비워두면 data/db.json 파일에 저장됩니다.
# Supabase 프로젝트 → Settings → API 에서 URL 과 service_role 키를 복사.
# ⚠️ service_role 키는 서버 전용 비밀키입니다. 절대 클라이언트/깃에 노출하지 마세요.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
